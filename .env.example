# ============================================
# AID Environment Configuration Template
# Copy this file to .env and fill in values
# ============================================

# ================== Application ==================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================== Database ==================
DATABASE_URL=postgresql://user:password@localhost:5432/aid_db
# For SQLite (development): DATABASE_URL=file:./dev.db

# ================== Redis (Optional) ==================
REDIS_URL=redis://localhost:6379

# ================== Authentication ==================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ================== API Keys ==================
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if using)
# OPENAI_API_KEY=sk-...

# ================== MCP Servers ==================
# Figma MCP (runs locally from Figma Desktop)
FIGMA_MCP_URL=http://127.0.0.1:3845/mcp

# ================== External Services ==================
# Jira / Atlassian Integration
ATLASSIAN_SITE_URL=https://your-org.atlassian.net
ATLASSIAN_USER_EMAIL=your-email@company.com
ATLASSIAN_API_TOKEN=your-jira-api-token

# GitHub Integration
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Figma Integration (optional - can also use Dev Mode local server)
FIGMA_API_KEY=figd_...

# ================== Feature Flags ==================
ENABLE_DEV_TOOLS=true
ENABLE_DEBUG_LOGGING=true

# ================== Telemetry ==================
# Set to 1 to disable telemetry
# NEXT_TELEMETRY_DISABLED=1
