# ============================================
# AID Environment Configuration Template
# Copy this file to .env and fill in values
# ============================================

# ================== Application ==================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================== Database ==================
DATABASE_URL=postgresql://user:password@localhost:5432/aid_db
# For SQLite (development): DATABASE_URL=file:./dev.db

# ================== Redis (Optional) ==================
REDIS_URL=redis://localhost:6379

# ================== Authentication ==================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ================== API Keys ==================
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (if using)
# OPENAI_API_KEY=sk-...

# ================== MCP Servers ==================
# Figma MCP (runs locally from Figma Desktop)
FIGMA_MCP_URL=http://127.0.0.1:3845/mcp

# ================== External Services ==================
# Jira / Atlassian Integration
ATLASSIAN_SITE_URL=https://your-org.atlassian.net
ATLASSIAN_USER_EMAIL=your-email@company.com
ATLASSIAN_API_TOKEN=your-jira-api-token

# GitHub Integration
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Figma Integration (optional - can also use Dev Mode local server)
FIGMA_API_KEY=figd_...

# ================== Nano Banana Pro (Optional) ==================
# AI-powered visual artifact generation - OPTIONAL feature
# Choose ONE provider and configure accordingly

# Option 1: Google AI Studio (recommended for quick start)
# Get key from: https://aistudio.google.com/apikey
# NANO_BANANA_PROVIDER=google
# GOOGLE_AI_API_KEY=your-google-ai-api-key

# Option 2: AI/ML API
# Get key from: https://aimlapi.com
# NANO_BANANA_PROVIDER=aimlapi
# AIML_API_KEY=your-aiml-api-key

# Option 3: Google Vertex AI (enterprise)
# Requires GCP project with Vertex AI enabled
# NANO_BANANA_PROVIDER=vertex
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# ================== Feature Flags ==================
ENABLE_DEV_TOOLS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_NANO_BANANA=false

# ================== Telemetry ==================
# Set to 1 to disable telemetry
# NEXT_TELEMETRY_DISABLED=1
