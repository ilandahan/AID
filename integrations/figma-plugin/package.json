{
  "name": "figma-atomic-design-extractor",
  "version": "1.0.0",
  "description": "Figma plugin for extracting components to Atomic Design System via MCP",
  "main": "dist/code.js",
  "scripts": {
    "build": "npm run build:code && npm run build:ui",
    "build:code": "esbuild code.ts --bundle --outfile=dist/code.js --format=iife --target=es2015",
    "build:ui": "node scripts/build-ui.js",
    "build:ui:legacy": "copy ui.html dist\\ui.html",
    "watch": "npm run watch:code & npm run watch:ui",
    "watch:code": "esbuild code.ts --bundle --outfile=dist/code.js --format=iife --target=es2015 --watch",
    "watch:ui": "chokidar 'ui.html' -c 'npm run build:ui'",
    "dev": "npm run build && npm run watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "clean": "rmdir /s /q dist 2>nul || echo dist not found",
    "prepublish": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "figma",
    "plugin",
    "atomic-design",
    "design-system",
    "mcp",
    "component-extraction"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@figma/plugin-typings": "^1.98.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "babel-jest": "^29.7.0",
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
