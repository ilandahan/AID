# Figma Plugin Server Environment
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API Key (Required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Local development - export to your project's src folder
# Example: /path/to/your/project/src
AID_PROJECT_PATH=

# Enable React component generation (default: true)
AID_GENERATE_REACT=true
