// AID Database Schema
// Prisma ORM schema definition

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User Management
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  projects  Project[]
  sessions  Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Role {
  USER
  ADMIN
}

// ============================================
// Project Management
// ============================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(DISCOVERY)
  userId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
  tasks     Task[]

  @@map("projects")
}

enum ProjectStatus {
  DISCOVERY
  PRD
  TECHSPEC
  DEVELOPMENT
  QA
  COMPLETED
  ARCHIVED
}

// ============================================
// Artifacts (Documents)
// ============================================

model Artifact {
  id        String       @id @default(cuid())
  type      ArtifactType
  title     String
  content   Json
  version   Int          @default(1)
  projectId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("artifacts")
}

enum ArtifactType {
  DISCOVERY
  PRD
  TECHSPEC
  QA_REPORT
}

// ============================================
// Task Tracking
// ============================================

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  projectId   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
