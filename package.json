{
  "name": "ai-fullstack-methodology",
  "version": "1.0.0",
  "description": "AI Full Stack Development Methodology - Transform requirements into production-ready software using Claude Code",
  "author": "Ilan Dahan",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --watchAll=false",
    "test:python": "cd memory-system && python -m pytest",
    "test:python:coverage": "cd memory-system && python -m pytest --cov=. --cov-report=html",
    "test:all": "npm run test:ci && npm run test:python:coverage",
    "test:sanity": "python -m pytest testing/e2e/ -v --tb=short -m \"not integration\"",
    "test:sanity:full": "python -m pytest testing/e2e/ -v --tb=short",
    "test:e2e": "python -m pytest testing/e2e/ -v",
    "test:e2e:install": "python -m pytest testing/e2e/test_installation.py -v",
    "test:e2e:mcp": "python -m pytest testing/e2e/test_mcp_sanity.py -v",
    "test:e2e:memory": "python -m pytest testing/e2e/test_memory_system_sanity.py -v",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:create": "node scripts/create-migration.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "generate:keys": "node scripts/generate-keys.js",
    "setup": "./install.sh",
    "new-project": "./scripts/init-project.sh",
    "clean:recordings": "find test-recordings/ -type f -not -name '.gitkeep' -not -name 'README.md' -mtime +7 -delete",
    "clean:recordings:all": "find test-recordings/ -type f -not -name '.gitkeep' -not -name 'README.md' -delete",
    "install:mcp": "npm run install:mcp:jira && npm run install:mcp:github && npm run install:mcp:postgres && npm run install:mcp:chrome",
    "install:mcp:jira": "npx -y @modelcontextprotocol/server-atlassian --help || true",
    "install:mcp:github": "npx -y @modelcontextprotocol/server-github --help || true",
    "install:mcp:postgres": "npx -y @modelcontextprotocol/server-postgres --help || true",
    "install:mcp:chrome": "npx -y chrome-devtools-mcp@latest --help || true",
    "security:audit": "npm audit && cd memory-system && pip-audit || true",
    "generate:diagrams": "npx ts-node docs/visuals/generate-llcms-diagrams.ts"
  },
  "dependencies": {
    "next": "^16.0.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sass": "^1.94.2",
    "pg": "^8.16.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "clsx": "^2.1.1",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/pg": "^8.15.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "supertest": "^7.1.4",
    "puppeteer": "^24.32.1",
    "prisma": "^6.1.0",
    "@svgr/webpack": "^8.1.0"
  },
  "optionalDependencies": {
    "chrome-devtools-mcp": "latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "ai-development",
    "methodology",
    "react",
    "nextjs",
    "typescript",
    "nodejs",
    "postgresql",
    "e2e",
    "full-stack"
  ],
  "overrides": {
    "jsdom": "^26.1.0",
    "glob": "^11.0.0"
  }
}
